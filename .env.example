# =============================================================================
# Security Agent Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# --- LLM Provider (choose one) ---
# Options: gemini, openai, anthropic, ollama, lmstudio
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-pro

# Gemini
GOOGLE_API_KEY=your-google-api-key

# OpenAI (optional)
OPENAI_API_KEY=your-openai-api-key

# Anthropic (optional)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Ollama (optional, local models)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# LM Studio (optional, local models via OpenAI-compatible API)
# How to enable:
#   1. Open LM Studio → go to "Developer" tab (left sidebar)
#   2. Load a model (e.g. qwen2.5-coder-32b, deepseek-r1, llama3.3)
#   3. Click "Start Server" — it runs at http://localhost:1234
#   4. Set LLM_PROVIDER=lmstudio below
#   5. Set LMSTUDIO_MODEL to the model identifier shown in LM Studio
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=

# --- External Tool APIs ---
# Acunetix
ACUNETIX_API_URL=https://your-acunetix-instance.com
ACUNETIX_API_KEY=your-acunetix-api-key

# Burp Suite Enterprise
BURP_API_URL=
BURP_API_KEY=

# OWASP ZAP
ZAP_API_URL=
ZAP_API_KEY=

# Shodan
SHODAN_API_KEY=your-shodan-api-key

# Metasploit RPC
METASPLOIT_RPC_HOST=127.0.0.1
METASPLOIT_RPC_PORT=55553
METASPLOIT_RPC_PASSWORD=your-msf-password

# --- Agent Settings ---
# Maximum time (seconds) for a single tool execution
TOOL_TIMEOUT=300
# Maximum total scan time (seconds)
MAX_SCAN_TIME=3600
# Output directory for reports
REPORT_OUTPUT_DIR=./reports
# Database path
DATABASE_PATH=./data/security_agent.db
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
